<IfModule mod_rewrite.c>
    RewriteEngine On

    # No reescribir si el archivo o directorio existe (assets físicos)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Resto de rutas → front controller
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>

# Bloquear acceso directo a archivos sensibles
<FilesMatch "\.(env|md|log|sqlite|sqlite-journal|ini|sql)$">
    Require all denied
</FilesMatch>

Options -Indexes
ServerSignature Off

# Cabeceras de seguridad (mod_headers)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>
