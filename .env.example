# FastPlay · variables de entorno (copia este archivo a .env y rellena los valores)

APP_ENV=development

GOOGLE_MAPS_API_KEY=

# === Google OAuth (login/registro con Google) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Base de datos (MySQL requerido) ===
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fastplay
DB_USER=root
DB_PASS=

# === Mail (SMTP) ===
MAIL_HOST=smtp.ionos.es
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USER=sadek@dksaa.com
MAIL_PASS=
MAIL_FROM=sadek@dksaa.com
MAIL_FROM_NAME=FastPlay

# === Stripe ===
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
