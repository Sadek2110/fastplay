# FastPlay · variables de entorno (copia este archivo a .env y rellena los valores)
# Las variables aqui declaradas pueden anularse por las variables del sistema
# o las definidas en el panel de hosting (Easypanel, Docker, Apache SetEnv...).

# Entorno: 'development' o 'production'
APP_ENV=development

# === Google Maps ===
# Crea la clave en Google Cloud Console (Maps JavaScript API).
# Si esta vacia, /campos usara Leaflet/OpenStreetMap como fallback.
GOOGLE_MAPS_API_KEY=

# === Base de datos (opcional, por defecto SQLite local) ===
# DB_DRIVER=sqlite | mysql | pgsql
DB_DRIVER=sqlite
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=fastplay
# DB_USER=fastplay
# DB_PASS=secret
