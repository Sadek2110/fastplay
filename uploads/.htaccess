Options -Indexes -ExecCGI

# Desactivar cualquier handler de scripts en este directorio
RemoveHandler .php .phtml .phtm .php3 .php4 .php5 .php7 .phps .phar .pl .py .jsp .asp .sh .cgi
RemoveType .php .phtml .phtm .php3 .php4 .php5 .php7 .phps .phar .pl .py .jsp .asp .sh .cgi

# Apache 2.4
<IfModule mod_authz_core.c>
    <FilesMatch "\.(php|phtml|phtm|phar|pl|py|jsp|asp|sh|cgi|exe|html?)$">
        Require all denied
    </FilesMatch>
</IfModule>

# Apache 2.2 fallback
<IfModule !mod_authz_core.c>
    <FilesMatch "\.(php|phtml|phtm|phar|pl|py|jsp|asp|sh|cgi|exe|html?)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

# Forzar tipo seguro a contenidos servidos
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>
